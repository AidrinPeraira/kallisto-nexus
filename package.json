{
  "name": "kallisto-nexus",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch apps --watch src --watch packages --ext ts --exec tsx apps/api/src/server.ts",
    "build": "tsc",
    "start": "node dist/apps/api/src/server.js",
    "infra:up": "docker-compose -f docker-compose.infra.yml up -d",
    "infra:down": "docker-compose -f docker-compose.infra.yml down",
    "db:migrate": "dotenv -e .env -- sh -c 'DATABASE_URL=$DIRECT_URL prisma migrate dev'",
    "db:migrate:create-only": "dotenv -e .env -- sh -c 'DATABASE_URL=$DIRECT_URL prisma migrate dev --create-only'",
    "db:deploy": "dotenv -e .env -- sh -c 'DATABASE_URL=$DIRECT_URL prisma migrate deploy'",
    "db:generate": "prisma generate",
    "db:studio": "dotenv -e .env -- sh -c 'DATABASE_URL=$DIRECT_URL prisma studio'",
    "db:reset": "dotenv -e .env -- sh -c 'DATABASE_URL=$DIRECT_URL prisma migrate reset'",
    "db:push": "dotenv -e .env -- sh -c 'DATABASE_URL=$DIRECT_URL prisma db push'",
    "db:pull": "dotenv -e .env -- sh -c 'DATABASE_URL=$DIRECT_URL prisma db pull'",
    "docker:infra:up": "pnpm infra:up",
    "docker:infra:down": "pnpm infra:down",
    "docker:build:prod": "docker build -t aidrinperaira/kallisto-nexus:latest -f Dockerfile.prod .",
    "docker:push": "docker push aidrinperaira/kallisto-nexus:latest",
    "docker:up:dev": "docker-compose -f docker-compose.dev.yml up -d --build",
    "docker:down:dev": "docker-compose -f docker-compose.dev.yml down",
    "docker:up:prod": "docker-compose -f docker-compose.prod.yml up -d --build",
    "docker:down:prod": "docker-compose -f docker-compose.prod.yml down"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.22.0",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "nodemon": "^3.1.14",
    "prisma": "^7.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "better-auth": "^1.5.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "install": "^0.13.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "pnpm": "^10.33.0",
    "resend": "^6.10.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  }
}
