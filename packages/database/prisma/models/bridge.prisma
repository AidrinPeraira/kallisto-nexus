// ─── PARENT ───────────────────────────────────────────────

model Bridge_ServiceProvider {
    id     String @id @default(uuid())
    userId String @unique
    spCode String @unique @default(dbgenerated("concat('SP-', nextval('app_sp_code_seq'))"))

    spType ServiceProviderType // organisation | professional | contractor

    // identity
    displayName    String // org name or full name
    profilePicture String?

    // address
    officeAddress String?
    officeEmail   String?
    officePhone   String?

    // services
    primaryServices     ServiceTypes[]
    subServices         ServiceTypes[]
    typicalProjectValue Int?
    isServicesAdded     Boolean        @default(false)

    // credentials (common subset)
    PAN                       String?
    GSTIN                     String?
    governmentIdType          GovernmentIdType?
    governmentIdNumber        String?
    professionalLicenseType   ProfessionalLicenseType?
    professionalLicenseNumber String?

    // bank details
    financeAccountId  String? // reference to Finance module record
    accountHolderName String?
    bankName          String?
    bankBranch        String?
    accountNumber     String? // store encrypted
    IFSCCode          String?
    UPIId             String?

    // portfolio
    portfolioId String?

    // consent details go here

    //   isPlatformConsentAdded Boolean @default(false)
    isIdentityAdded       Boolean @default(false)
    isAddressAdded        Boolean @default(false)
    isPortfolioAdded      Boolean @default(false)
    isCredentialsAdded    Boolean @default(false)
    isBankDetailsAdded    Boolean @default(false)
    isRepresentativeAdded Boolean @default(false)

    status    ServiceProviderStatus @default(onboarding)
    createdAt DateTime              @default(now())
    updatedAt DateTime              @updatedAt

    // relations
    serviceAreas_Bridge Bridge_ServiceArea[]
    organisationProfile Bridge_OrganisationProfile?
    professionalProfile Bridge_ProfessionalProfile?
    contractorProfile   Bridge_ContractorProfile?
    bridgePortfolio     Bridge_Portfolio?

    @@map("bridge_service_provider")
}

// ─── SUB TABLES ───────────────────────────────────────────
model Bridge_OrganisationProfile {
    id                String                 @id @default(uuid())
    serviceProviderId String                 @unique
    serviceProvider   Bridge_ServiceProvider @relation(fields: [serviceProviderId], references: [id])

    brandName           String?
    brandLogo           String?
    organisationType    OrganisationType?
    yearOfEstablishment Int?

    // org-specific credentials
    businessProofType  BusinessProofType?
    businessProofImage String?
    tradeLicense       String?
    insurance          String?

    // representative
    representativeName         String?
    representativeDesignation  String?
    representativeMobile       String?
    representativeGovtIDType   GovernmentIdType?
    representativeGovtIDNumber String?
    representativeGovtIDProof  String?

    @@map("bridge_organisation_profile")
}

model Bridge_ProfessionalProfile {
    id                String                 @id @default(uuid())
    serviceProviderId String                 @unique
    serviceProvider   Bridge_ServiceProvider @relation(fields: [serviceProviderId], references: [id])

    workingSince Int? // years of experience

    @@map("bridge_professional_profile")
}

model Bridge_ContractorProfile {
    id                String                 @id @default(uuid())
    serviceProviderId String                 @unique
    serviceProvider   Bridge_ServiceProvider @relation(fields: [serviceProviderId], references: [id])

    workingSince Int?
    // workerCount  Int? not needed for service provider

    @@map("bridge_contractor_profile")
}

// ─── SERVICE AREA TABLES ───────────────────────────────────────────
model Bridge_ServiceArea {
    id                String                 @id @default(uuid())
    serviceProviderId String
    serviceProvider   Bridge_ServiceProvider @relation(fields: [serviceProviderId], references: [id])

    city        String
    isPrimary   Boolean                               @default(false)
    centerPoint Unsupported("geography(Point, 4326)")
    radiusKm    Float
    createdAt   DateTime                              @default(now())
    updatedAt   DateTime                              @updatedAt

    @@map("bridge_service_area")
}

// ─── PORTFOLIO TABLES ───────────────────────────────────────────
model Bridge_Portfolio {
    id                String                 @id @default(uuid())
    serviceProviderId String                 @unique
    serviceProvider   Bridge_ServiceProvider @relation(fields: [serviceProviderId], references: [id])

    portfolioWebsite String?
    isPublic         Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    projects Bridge_PortfolioProject[]

    @@map("bridge_portfolio")
}

model Bridge_PortfolioProject {
    id          String           @id @default(uuid())
    portfolioId String
    portfolio   Bridge_Portfolio @relation(fields: [portfolioId], references: [id])

    // project info
    projectName    String
    location       String?
    projectType    ProjectType // Residential | Commercial | Industrial | Hospitality etc
    scope          ProjectScope[] // Structure | Interior | MEP | Landscape etc
    completionYear Int?
    budgetValue    Int?
    budgetCurrency String?        @default("INR")

    // media
    thumbnailUrl String?
    photos       String[]

    // verification
    isKallistoVerified Boolean @default(false)

    // testimonial
    testimonialClientName  String?
    testimonialClientPhone String?
    testimonialText        String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("bridge_portfolio_project")
}
