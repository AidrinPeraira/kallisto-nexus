{
  "compilerOptions": {
    /* Base Options */
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["es2022"],

    /* Path Mapping */
    "paths": {
      "@src/*": ["./src/*"],
      "@packages/*": ["./packages/*"]
    },

    /* Strictness & Safety */
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    /* Module & Interop */
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,

    /* Output Control */
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "allowJs": true
  },
  "include": ["src/**/*", "packages/**/*", "apps/**/*"],
  "exclude": ["node_modules"]
}
